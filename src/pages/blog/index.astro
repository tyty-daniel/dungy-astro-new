---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
);
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			ul {
				list-style-type: none;
				padding: unset;
			}
			ul li {
				display: flex;
			}
			ul li :global(time) {
				flex: 0 0 130px;
				font-style: italic;
				color: #595959;
			}
			ul li a:visited {
				color: #8e32dc;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="p-2 m-4">
				<h1 class="text-3xl text-center">dungy's blog</h1>
				<p class="text-lg text-center">ramblings from a yaoi-obsessed canaille</p>
			</div>
			<section>
				<ul>
					{
						posts.map((post) => (
						<div class="border-2 p-2 border-dotted border-blue-300 m-4 max-h-96">
							<time date={post.data.pubDate}>
								{new Date(post.data.pubDate).toLocaleDateString('en-us', {
									year: 'numeric',
									month: 'short',
									day: 'numeric',
								})}
							</time>
							<a href={`/blog/${post.slug}/`} class="my-3 text-2xl text-center">{post.data.title}</a>
							<div class="flex flex-wrap justify-center">
							<img src={post.data.heroImage} class="object-cover w-96 h-60 m-2"/>
							</div>
							<p class="italic text-m p-1 text-center">{post.data.description}</p>
							</div>
							
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
