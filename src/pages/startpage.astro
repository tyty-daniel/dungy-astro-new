---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import ushijima from "../images/ushijima-55.jpg";
import thoma from "../images/thoma-aether.jpg";
import todoroki from "../images/todoroki.jpg";
---
<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header title={SITE_TITLE} />
		<main class=" max-w-4xl p-2 mx-auto md:p-4">
            <div class="p-5 mx-auto text-center">
                <h1 class="text-2xl">daniel! お茶はいかがですか</h1>
               </div>
               <div class="px-2">
                   <div class="flex -mx-2">
                     <div class="w-1/3 px-2">
                       <div class="bg-white border border-blue-300 p-2">
                       <h2 class="bg-purple-400 font-bold">chans</h2>
                       <ul>
                           <a href="https://lainchan.org/mega/index.html" target="_blank"><li>lainchan</li></a>
                           <a href="https://boards.4channel.org/g/" target="_blank"><li>/g/</li></a>
                           <a href="https://boards.4channel.org/his/" target="_blank"><li>/his/</li></a>
                           <a href="https://boards.4channel.org/lit/" target="_blank"><li>/lit/</li></a>
                           <a href="https://leftypol.org" target="_blank"><li>leftypol</li></a>
                       </ul>
                       </div>
                       </div>
                       <div class="w-1/3 px-2">
                         <img src={todoroki} alt="todoroki fanart" />
                          </div>
                         <div class="w-1/3 px-2">
                       <div class="bg-white border border-blue-300 p-2">
                         <h2 class="bg-purple-400 font-bold">soc</h2>
                         <ul>
                           <a href="https://bae.st" target="_blank"><li>baest</li></a>
                           <a href="https://www.youtube.com" target="_blank"><li>youtube</li></a>
                         </ul>
                         </div>
                         </div>
                   </div>
            
               </div>
               <div class="p-5">
                   <div class="flex -mx-2">
                     <div class="w-1/3 px-2">
                       <img src={thoma} alt="thoma and aether fanart"/>
                       </div>
                       <div class="w-1/3 px-2">
                       <div class="bg-white border border-blue-300 p-2">
                         <h2 class="bg-purple-400 font-bold">other</h2>
                         <ul>
                           <a href="https://marxists.org" target="_blank"><li>marxists</li></a>
                           <a href="https://www.amazon.co.uk" target="_blank"><li>amazon</li></a>
                           <a href="https://archiveofourown.org" target="_blank"><li>ao3</li></a>
                         </ul>
                         </div>
                          </div>
                          <div class="w-1/3 px-2">
                                <img src={ushijima} alt="ranok Far Beyond The World"/>
                       </div>
                   </div>
            
               </div>
            </main>
            </body>
            </html>