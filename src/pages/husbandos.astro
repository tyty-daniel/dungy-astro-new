---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import kisumi from "../images/kisumi-2.jpg";
import sousuke from "../images/sousuke-17.jpg";
import makoto from "../images/makoto-17.jpg";
import seijuurou from "../images/Mikoshiba-01.jpg";
import asahi from "../images/asahi-3.jpg";
import kagami from "../images/kagami-01.png";
import aomine from "../images/aomine-19.jpg";
import kise from "../images/kise-01.png";
import thoma from "../images/thoma-02.jpg";
import tartaglia from "../images/tartaglia-01.png";
import itto from "../images/itto-1.jpg";
import kageyama from "../images/kageyama-20.jpg";
import atsumu from "../images/atsumu-1.jpg";
import ushijima from "../images/ushijima-73.jpg";
import dimitri from "../images/dimitri-2.jpg";
import sylvain from "../images/sylvain-2.jpg";
import dedue from "../images/dedue-1.jpg";
import minato from "../images/minato-1.jpg";
import sidon from "../images/sidon-1.jpg";
import loid from "../images/loid-1.jpg";

---
<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title="dungy's husbandos" description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header title={SITE_TITLE} />
        <main>
            <div class="m-1 p-2 mx-md border-blue-300 text-center">
                <h1 class="text-4xl font-sans">my husbandos</h1>
                <p>my favourite fictional anime men accured throughout the years</p>
            </div>
            <div class="flex justify-center items-center">
            <div class="border-dashed border-2 border-blue-900 text-center font-sans max-w-md p-1">
                <p class="text-sm">jump to: <a href="#free">free!</a> | <a href="#knb">kuroko no basuke</a> | <a href="#genshin">genshin impact</a> | <a href="#haikyuu">haikyuu</a> | <a href="#fe">fire emblem</a> | <a href="#other">other</a></p>
            </div>
            </div>
            <div class="m-1 mx-md text-center">
                <h2 class="text-2xl font-sans" id="free">Free!</h2>
            <div class="flex flex-row p-1">
                <a href="/husbandos/kisumi">
                <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                    <h3 class="text-xl font-sans">Kisumi Shigino</h3>
                    <img src={kisumi}>
                    <p>src:</p>
                    <h3 class="text-sm">links</h3>
                    <ul><li>
                        <a href="/husbandos/kisumi">kisumi</a></li></ul>
                </div>
            </a>
                <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                    <h3 class="text-xl font-sans">Yamazaki Sousuke</h3>
                    <img src={sousuke}>
                    <p>src:</p>
                    <h3 class="text-sm">links</h3>
                </div>
                <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                    <h3 class="text-xl font-sans">Makoto Tachibana</h3>
                    <img src={makoto}>
                    <p>src:</p>
                    <h3 class="text-sm">links</h3>
                </div>
            </div>
            <div class="flex flex-row">
                <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                <h3 class="text-xl font-sans">Mikoshiba Seijuurou</h3>
                    <img src={seijuurou}>
                    <p>src:</p>
                    <h3 class="text-sm">links</h3>
                    </div>
                    <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                        <h3 class="text-xl font-sans">Shiina Asahi</h3>
                            <img src={asahi}>
                            <p>src:</p>
                            <h3 class="text-sm">links</h3>
                            </div>
             </div>
            </div>
            <div class="m-1 mx-md text-center">
                <h2 class="text-2xl font-sans" id="knb">Kuroko No Basuke</h2>
                <div class="flex flex-row">
                    <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                        <h3 class="text-xl font-sans">Kagami Taiga</h3>
                        <img src={kagami}>
                        <p>src:</p>
                        <h3 class="text-sm">links</h3>
                    </div>
                    <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                        <h3 class="text-xl font-sans">Aomine Daiki</h3>
                        <img src={aomine}>
                        <p>src:</p>
                        <h3 class="text-sm">links</h3>
                    </div>
                    <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                        <h3 class="text-xl font-sans">Kise Ryouta</h3>
                        <img src={kise}>
                        <p>src:</p>
                        <h3 class="text-sm">links</h3>
                    </div>
                </div>
                </div>
                <div class="m-1 mx-md text-center">
                    <h2 class="text-2xl font-sans" id="genshin">Genshin Impact</h2>
                    <div class="flex flex-row">
                        <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                            <h3 class="text-xl font-sans">Thoma</h3>
                            <img src={thoma}>
                            <p>src:</p>
                            <h3 class="text-sm">links</h3>
                        </div>
                        <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                            <h3 class="text-xl font-sans">Tartaglia</h3>
                            <img src={tartaglia}>
                            <p>src:</p>
                            <h3 class="text-sm">links</h3>
                        </div>
                        <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                            <h3 class="text-xl font-sans">Arataki Itto</h3>
                            <img src={itto}>
                            <p>src:</p>
                            <h3 class="text-sm">links</h3>
                        </div>
                    </div>
                    </div>
                    <div class="m-1 mx-md text-center">
                        <h2 class="text-2xl font-sans" id="haikyuu">Haikyuu</h2>
                        <div class="flex flex-row">
                            <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                                <h3 class="text-xl font-sans">Kageyama Tobio</h3>
                                <img src={kageyama}>
                                <p>src:</p>
                                <h3 class="text-sm">links</h3>
                            </div>
                            <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                                <h3 class="text-xl font-sans">Miya Atsumu</h3>
                                <img src={atsumu}>
                                <p>src:</p>
                                <h3 class="text-sm">links</h3>
                            </div>
                            <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                                <h3 class="text-xl font-sans">Ushijima Wakatoshi</h3>
                                <img src={ushijima}>
                                <p>src:</p>
                                <h3 class="text-sm">links</h3>
                            </div>
                        </div>
                        </div>
                    <div class="m-1 mx-md text-center">
                            <h2 class="text-2xl font-sans" id="fe">Fire Emblem Three Houses</h2>
                            <div class="flex flex-row">
                                <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                                    <h3 class="text-xl font-sans">Dimitri Alexandre Blaidydd</h3>
                                    <img src={dimitri}>
                                    <p>src:</p>
                                    <h3 class="text-sm">links</h3>
                                </div>
                                <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                                    <h3 class="text-xl font-sans">Sylvain Jose Gautier</h3>
                                    <img src={sylvain}>
                                    <p>src:</p>
                                    <h3 class="text-sm">links</h3>
                                </div>
                                <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                                    <h3 class="text-xl font-sans">Dedue Molinaro</h3>
                                    <img src={dedue}>
                                    <p>src:</p>
                                    <h3 class="text-sm">links</h3>
                                </div>
                            </div>
                            </div>
                            <div class="m-1 mx-md text-center">
                                <h2 class="text-2xl font-sans" id="other">Other</h2>
                                <div class="flex flex-row">
                                    <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                                        <h3 class="text-xl font-sans">Minato Namikaze</h3>
                                        <img src={minato}>
                                        <p>src:</p>
                                        <h3 class="text-sm">links</h3>
                                    </div>
                                    <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                                        <h3 class="text-xl font-sans">Sidon</h3>
                                        <img src={sidon}>
                                        <p>src:</p>
                                        <h3 class="text-sm">links</h3>
                                    </div>
                                    <div class="basis-1/3 hover:basis-1/2 duration-200 p-1">
                                        <h3 class="text-xl font-sans">Loid Forger</h3>
                                        <img src={loid}>
                                        <p>src:</p>
                                        <h3 class="text-sm">links</h3>
                                    </div>
                                </div>
                                </div>

                                <Footer />
        </main>
    </body>
</html>